generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  RECEPTIONIST
}
enum Gender {
  MALE
  FEMALE
  OTHER
}
enum AppointmentStatus {
  PENDING
  CONFIRMED
  COMPLETED
  CANCELLED
  NO_SHOW
}
enum VisitStatus {
  UPCOMING
  COMPLETED
  CANCELLED
  NO_SHOW
}
enum PaymentMethod {
  CASH
  CARD
  BANK_TRANSFER
  OTHER
}
enum TreatmentStatus {
  PROPOSED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}
enum InstallmentStatus {
  UNPAID
  PARTIALLY_PAID
  PAID
  OVERDUE
}
enum ToothStatus {
  HEALTHY
  CARIES
  FILLING
  ROOT_CANAL
  CROWN
  IMPLANT
  MISSING
  EXTRACTION_NEEDED
  CLEANING_NEEDED
  OTHER
}

model User {
  id           String        @id @default(cuid())
  email        String        @unique
  name         String
  passwordHash String
  role         UserRole      @default(ADMIN)
  activityLogs ActivityLog[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

model Patient {
  id                    String          @id @default(cuid())
  fileNumber            String          @unique
  firstName             String
  fatherName            String?
  lastName              String
  fullName              String
  photoDataUrl          String?         @db.Text
  gender                Gender
  birthDate             DateTime?
  phone                 String
  alternativePhone      String?
  email                 String?
  address               String?
  city                  String?
  occupation            String?
  maritalStatus         String?
  emergencyContactName  String?
  emergencyContactPhone String?
  emergencyRelation     String?
  notes                 String?         @db.Text
  isArchived            Boolean         @default(false)
  medicalHistory        MedicalHistory?
  appointments          Appointment[]
  visits                Visit[]
  treatmentPlans        TreatmentPlan[]
  toothRecords          ToothRecord[]
  payments              Payment[]
  installments          Installment[]
  patientNotes          PatientNote[]
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt

  @@index([fullName])
  @@index([phone])
  @@index([isArchived])
}

model MedicalHistory {
  id                String   @id @default(cuid())
  patientId         String   @unique
  patient           Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  bloodType         String?
  chronicDiseases   String?  @db.Text
  allergies         String?  @db.Text
  medications       String?  @db.Text
  previousSurgeries String?  @db.Text
  pregnant          Boolean  @default(false)
  smoking           Boolean  @default(false)
  hypertension      Boolean  @default(false)
  diabetes          Boolean  @default(false)
  heartDisease      Boolean  @default(false)
  bleedingDisorder  Boolean  @default(false)
  notes             String?  @db.Text
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model Appointment {
  id        String            @id @default(cuid())
  patientId String
  patient   Patient           @relation(fields: [patientId], references: [id], onDelete: Cascade)
  startAt   DateTime
  endAt     DateTime
  type      String
  doctor    String            @default("الدكتور عمار درويش")
  status    AppointmentStatus @default(PENDING)
  notes     String?           @db.Text
  visit     Visit?
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  @@index([startAt])
  @@index([status])
}

model Visit {
  id            String       @id @default(cuid())
  patientId     String
  patient       Patient      @relation(fields: [patientId], references: [id], onDelete: Cascade)
  appointmentId String?      @unique
  appointment   Appointment? @relation(fields: [appointmentId], references: [id], onDelete: SetNull)
  sessionNumber Int
  date          DateTime
  type          String
  teeth         String?
  reason        String?      @db.Text
  diagnosis     String?      @db.Text
  procedure     String?      @db.Text
  materials     String?      @db.Text
  prescription  String?      @db.Text
  aftercare     String?      @db.Text
  doctorNotes   String?      @db.Text
  status        VisitStatus  @default(COMPLETED)
  costCents     Int          @default(0)
  paidCents     Int          @default(0)
  nextFollowUp  DateTime?
  payments      Payment[]
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@index([patientId, date])
}

model TreatmentPlan {
  id              String          @id @default(cuid())
  patientId       String
  patient         Patient         @relation(fields: [patientId], references: [id], onDelete: Cascade)
  name            String
  description     String?         @db.Text
  teeth           String?
  sessionCount    Int             @default(1)
  costCents       Int             @default(0)
  startDate       DateTime?
  expectedEndDate DateTime?
  status          TreatmentStatus @default(PROPOSED)
  notes           String?         @db.Text
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
}

model ToothRecord {
  id                 String      @id @default(cuid())
  patientId          String
  patient            Patient     @relation(fields: [patientId], references: [id], onDelete: Cascade)
  toothNumber        Int
  status             ToothStatus @default(HEALTHY)
  requiredTreatment  String?
  completedTreatment String?
  costCents          Int         @default(0)
  notes              String?     @db.Text
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt

  @@unique([patientId, toothNumber])
}

model Payment {
  id            String        @id @default(cuid())
  patientId     String
  patient       Patient       @relation(fields: [patientId], references: [id], onDelete: Restrict)
  visitId       String?
  visit         Visit?        @relation(fields: [visitId], references: [id], onDelete: SetNull)
  receiptNumber String        @unique
  paidAt        DateTime      @default(now())
  amountCents   Int
  method        PaymentMethod @default(CASH)
  receiver      String?
  notes         String?       @db.Text
  deletedAt     DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([paidAt])
  @@index([deletedAt])
}

model Installment {
  id              String            @id @default(cuid())
  patientId       String
  patient         Patient           @relation(fields: [patientId], references: [id], onDelete: Cascade)
  amountCents     Int
  dueDate         DateTime
  status          InstallmentStatus @default(UNPAID)
  paidAmountCents Int               @default(0)
  notes           String?           @db.Text
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  @@index([dueDate])
}

model ExpenseCategory {
  id        String    @id @default(cuid())
  name      String    @unique
  expenses  Expense[]
  createdAt DateTime  @default(now())
}

model Expense {
  id             String           @id @default(cuid())
  categoryId     String?
  category       ExpenseCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  expenseNumber  String           @unique
  name           String
  description    String?          @db.Text
  amountCents    Int
  date           DateTime
  method         PaymentMethod    @default(CASH)
  vendor         String?
  invoiceNumber  String?
  invoiceDataUrl String?          @db.Text
  notes          String?          @db.Text
  deletedAt      DateTime?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  @@index([date])
  @@index([deletedAt])
}

model PatientNote {
  id        String   @id @default(cuid())
  patientId String
  patient   Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  title     String
  body      String   @db.Text
  type      String?
  priority  String?  @default("NORMAL")
  pinned    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ActivityLog {
  id          String   @id @default(cuid())
  userId      String?
  user        User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  action      String
  description String   @db.Text
  createdAt   DateTime @default(now())

  @@index([createdAt])
}

model ClinicSettings {
  id                     String   @id @default("clinic")
  clinicName             String   @default("عيادة الدكتور عمار درويش")
  doctorName             String   @default("الدكتور عمار درويش")
  phone                  String?
  email                  String?
  address                String?
  currency               String   @default("SYP")
  defaultAppointmentMins Int      @default(30)
  workingHours           String?
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
}
